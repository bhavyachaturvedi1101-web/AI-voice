# ─── SignalWire ───────────────────────────────────────────────────────────────
# Get these from: app.signalwire.com → Settings
SIGNALWIRE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SIGNALWIRE_AUTH_TOKEN=PTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SIGNALWIRE_PHONE_NUMBER=+1xxxxxxxxxx
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com

# ─── Groq (Free AI) ───────────────────────────────────────────────────────────
# Get free API key from: console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model options (all free): llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
GROQ_MODEL=llama3-8b-8192

# ─── Google TTS (Optional — Free 1M chars/month) ──────────────────────────────
# Get from: console.cloud.google.com → Text-to-Speech API
# Leave blank to use SignalWire's built-in <Say> voices (always free)
GOOGLE_TTS_KEY=

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Free tier at: mongodb.com/atlas (M0 cluster)
MONGODB_URI=mongodb://localhost:27017/ai-voice-agent

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Ngrok / Public URL ───────────────────────────────────────────────────────
# Run: npx ngrok http 3000  — then paste your https URL here
BASE_URL=https://your-ngrok-url.ngrok-free.app

# ─── AI Agent Config ─────────────────────────────────────────────────────────
AGENT_NAME=Aria
AGENT_SYSTEM_PROMPT=You are Aria, a friendly and helpful AI voice assistant. Keep your responses concise and conversational — no more than 2-3 sentences per reply. Be warm, professional, and helpful.
